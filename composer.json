{
    "name": "x-laravel/spatie-media-library-uuid-path",
    "description": "A UUID-based path generator for spatie/laravel-medialibrary.",
    "keywords": ["laravel", "spatie", "media-library", "path-generator", "uuid"],
    "license": "MIT",
    "authors": [
        {
            "name": "X-Adam",
            "email": "www@mehmetogmen.com.tr",
            "homepage": "https://mehmetogmen.com.tr"
        }
    ],
    "require": {
        "php": "^8.2",
        "spatie/laravel-medialibrary": "^11.0"
    },
    "require-dev": {
        "orchestra/testbench": "^10.0|^11.0",
        "phpunit/phpunit": "^11.0|^12.0",
        "mockery/mockery": "^1.0"
    },
    "autoload": {
        "psr-4": {
            "XLaravel\\SpatieMediaLibraryUuidPath\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "XLaravel\\SpatieMediaLibraryUuidPath\\Tests\\": "tests/"
        }
    },
    "scripts": {
        "test": "phpunit"
    },
    "extra": {
        "laravel": {
            "providers": [
                "XLaravel\\SpatieMediaLibraryUuidPath\\MediaLibraryUuidPathServiceProvider"
            ]
        }
    }
}
